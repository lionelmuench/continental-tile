---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us - Get a Quote"
  description="Contact Continental Tile Contractors for tile, LVT/LVP, and carpet installation quotes. Serving NJ, NY, CT, and ME. Call 914-348-3400."
>
  {/* Page Header */}
  <section class="relative py-20 bg-brand-blue border-b border-brand-accent/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-xl">
        <p class="font-sans text-xs font-bold uppercase tracking-[0.25em] text-brand-accent mb-4">Get in Touch</p>
        <h1 class="font-serif text-4xl md:text-5xl font-bold text-brand-bg mb-5">Contact Us</h1>
        <p class="font-sans text-brand-bg/70 text-base leading-relaxed">
          Commercial build, renovation, or residential project. Tell us what you're working on and we'll get back to you quickly.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
        
        {/* Contact Info */}
        <div>
          {/* Phone - primary CTA */}
          <div class="mb-10 p-8 bg-brand-blue text-brand-bg">
            <p class="font-sans text-xs uppercase tracking-widest text-brand-accent font-bold mb-3">Fastest way to reach us</p>
            <a href="tel:9143483400" class="font-serif text-4xl font-bold text-brand-bg hover:text-brand-accent transition-colors block mb-1">
              914-348-3400
            </a>
            <p class="font-sans text-brand-bg/60 text-sm">Call or text anytime during business hours.</p>
          </div>

          <div class="space-y-8">
            <div class="flex items-start gap-5">
              <div class="w-10 h-10 bg-brand-bg border border-gray-200 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="h-5 w-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-sans text-xs font-bold uppercase tracking-widest text-gray-400 mb-1.5">Email</h3>
                <a href="mailto:Info@continentaltileinc.com" class="font-sans text-brand-blue hover:text-brand-accent transition-colors font-semibold">
                  Info@continentaltileinc.com
                </a>
              </div>
            </div>

            <div class="flex items-start gap-5">
              <div class="w-10 h-10 bg-brand-bg border border-gray-200 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="h-5 w-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-sans text-xs font-bold uppercase tracking-widest text-gray-400 mb-1.5">Office</h3>
                <p class="font-sans text-gray-700 leading-relaxed">
                  195 S Broadway<br />
                  Tarrytown, NY 10591
                </p>
              </div>
            </div>

            <div class="flex items-start gap-5">
              <div class="w-10 h-10 bg-brand-bg border border-gray-200 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="h-5 w-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
                </svg>
              </div>
              <div>
                <h3 class="font-sans text-xs font-bold uppercase tracking-widest text-gray-400 mb-1.5">Areas Served</h3>
                <p class="font-sans text-gray-700 leading-relaxed">
                  New York · New Jersey · Connecticut · Maine
                </p>
                <a href="/areas" class="font-sans text-xs text-brand-accent hover:underline mt-1 block">See all locations →</a>
              </div>
            </div>
          </div>
        </div>

        {/* Contact Form */}
        <div class="bg-brand-bg p-8 sm:p-10 border-t-4 border-brand-accent">
          <h2 class="font-serif text-2xl font-bold text-brand-blue mb-2">Send a Message</h2>
          <p class="font-sans text-gray-500 text-sm mb-8">We typically respond within one business day.</p>
          <form id="contact-form" class="space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="first-name" class="block text-xs font-bold font-sans text-brand-blue mb-2 uppercase tracking-wide">First Name</label>
                <input type="text" name="first-name" id="first-name" class="block w-full border border-gray-300 focus:ring-2 focus:ring-brand-accent focus:border-brand-accent p-3 bg-white text-sm" required />
              </div>
              <div>
                <label for="last-name" class="block text-xs font-bold font-sans text-brand-blue mb-2 uppercase tracking-wide">Last Name</label>
                <input type="text" name="last-name" id="last-name" class="block w-full border border-gray-300 focus:ring-2 focus:ring-brand-accent focus:border-brand-accent p-3 bg-white text-sm" required />
              </div>
            </div>

            <div>
              <label for="email" class="block text-xs font-bold font-sans text-brand-blue mb-2 uppercase tracking-wide">Email</label>
              <input type="email" name="email" id="email" class="block w-full border border-gray-300 focus:ring-2 focus:ring-brand-accent focus:border-brand-accent p-3 bg-white text-sm" required />
            </div>

            <div>
              <label for="phone" class="block text-xs font-bold font-sans text-brand-blue mb-2 uppercase tracking-wide">Phone <span class="font-normal text-gray-400 normal-case tracking-normal">(optional)</span></label>
              <input type="tel" name="phone" id="phone" class="block w-full border border-gray-300 focus:ring-2 focus:ring-brand-accent focus:border-brand-accent p-3 bg-white text-sm" />
            </div>

            <div>
              <label for="project-type" class="block text-xs font-bold font-sans text-brand-blue mb-2 uppercase tracking-wide">Project Type</label>
              <select id="project-type" name="project-type" class="block w-full border border-gray-300 focus:ring-2 focus:ring-brand-accent focus:border-brand-accent p-3 bg-white text-sm text-gray-700">
                <option value="">Select one...</option>
                <option>Commercial - New Construction</option>
                <option>Commercial - Renovation</option>
                <option>Residential</option>
                <option>Multifamily / Mixed-Use</option>
                <option>Other</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-xs font-bold font-sans text-brand-blue mb-2 uppercase tracking-wide">Project Details</label>
              <textarea id="message" name="message" rows="4" placeholder="Describe the project (location, scope, timeline, flooring type...)" class="block w-full border border-gray-300 focus:ring-2 focus:ring-brand-accent focus:border-brand-accent p-3 bg-white text-sm" required></textarea>
            </div>

            <button type="submit" class="w-full py-4 px-8 border border-transparent text-xs font-bold uppercase tracking-widest font-sans text-brand-bg bg-brand-blue hover:bg-brand-accent focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-blue transition-colors duration-300">
              Submit Inquiry
            </button>
          </form>

          <script>
            const form = document.getElementById('contact-form');
            if (form) {
              const submitBtn = form.querySelector('button[type="submit"]');

              form.addEventListener('submit', async (e) => {
                  e.preventDefault();

                  const formData = new FormData(form);
                  formData.append("access_key", "7cd0748a-fbb6-4341-b86e-0defd118c29f");

                  // Add a from_name to make emails nicer
                  const firstName = formData.get("first-name") || "";
                  const lastName = formData.get("last-name") || "";
                  if (firstName || lastName) {
                    formData.append("from_name", `${firstName} ${lastName}`.trim());
                  }

                  const originalText = submitBtn.textContent;

                  submitBtn.textContent = "Sending...";
                  submitBtn.disabled = true;

                  try {
                      const response = await fetch("https://api.web3forms.com/submit", {
                          method: "POST",
                          body: formData
                      });

                      const data = await response.json();

                      if (response.ok) {
                          alert("Success! Your message has been sent.");
                          form.reset();
                      } else {
                          alert("Error: " + data.message);
                      }
                  } catch (error) {
                      alert("Something went wrong. Please try again.");
                  } finally {
                      submitBtn.textContent = originalText;
                      submitBtn.disabled = false;
                  }
              });
            }
          </script>
        </div>
      </div>
    </div>
  </section>
  
  {/* Map */}
  <section class="h-80 w-full bg-gray-200">
    <iframe 
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3013.916174092494!2d-73.861715684581!3d41.06646737929452!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c2c069bc926e85%3A0xc6cb1dc2d5c8088!2s195%20S%20Broadway%2C%20Tarrytown%2C%20NY%2010591!5e0!3m2!1en!2sus!4v1655123456789!5m2!1en!2sus" 
      width="100%" 
      height="100%" 
      style="border:0;" 
      allowfullscreen="" 
      loading="lazy" 
      title="Continental Tile Contractors office location"
      referrerpolicy="no-referrer-when-downgrade">
    </iframe>
  </section>
</BaseLayout>
