---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact Us">
  {/* Page Header */}
  <section class="relative py-24 bg-brand-bg border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-serif text-5xl md:text-6xl font-bold text-brand-blue mb-6">Contact Us</h1>
      <p class="font-sans text-lg text-gray-600 max-w-2xl mx-auto uppercase tracking-widest font-bold">
        Let's Discuss Your Next Project
      </p>
    </div>
  </section>

  <section class="py-24 bg-white relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
        
        {/* Contact Info */}
        <div>
          <h2 class="font-serif text-4xl font-bold text-brand-blue mb-8">Get In Touch</h2>
          <p class="font-sans text-gray-600 mb-12 text-lg leading-relaxed">
            Whether you are planning a large-scale commercial build or a specialized residential renovation, our team is ready to provide expert guidance and unparalleled installation services.
          </p>
          
          <div class="space-y-10">
            <div class="flex items-start">
              <div class="flex-shrink-0 mt-1">
                <div class="w-12 h-12 bg-brand-blue flex items-center justify-center text-brand-accent">
                  <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </div>
              </div>
              <div class="ml-6">
                <h3 class="font-sans text-sm font-bold uppercase tracking-widest text-brand-blue mb-2">Office Location</h3>
                <p class="font-sans text-gray-600 leading-relaxed text-lg">
                  195 S Broadway<br />
                  Tarrytown, NY 10591
                </p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="flex-shrink-0 mt-1">
                <div class="w-12 h-12 bg-brand-blue flex items-center justify-center text-brand-accent">
                  <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </div>
              </div>
              <div class="ml-6">
                <h3 class="font-sans text-sm font-bold uppercase tracking-widest text-brand-blue mb-2">Phone</h3>
                <p class="font-sans text-gray-600 leading-relaxed text-lg">
                  <a href="tel:9143483400" class="hover:text-brand-accent transition-colors font-semibold">914.348.3400</a>
                </p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="flex-shrink-0 mt-1">
                <div class="w-12 h-12 bg-brand-blue flex items-center justify-center text-brand-accent">
                  <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
              </div>
              <div class="ml-6">
                <h3 class="font-sans text-sm font-bold uppercase tracking-widest text-brand-blue mb-2">Email</h3>
                <p class="font-sans text-gray-600 leading-relaxed text-lg">
                  <a href="mailto:lisa@continentaltileinc.com" class="hover:text-brand-accent transition-colors">lisa@continentaltileinc.com</a>
                </p>
              </div>
            </div>
          </div>
        </div>

        {/* Contact Form */}
        <div class="bg-brand-bg p-8 sm:p-12 shadow-xl border-t-4 border-brand-accent">
          <h3 class="font-serif text-3xl font-bold text-brand-blue mb-8">Send a Message</h3>
          <form class="space-y-6" action="#" method="POST" onsubmit="event.preventDefault(); alert('Form submission is a placeholder.');">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="first-name" class="block text-sm font-bold font-sans text-brand-blue mb-2 uppercase tracking-wide">First Name</label>
                <input type="text" name="first-name" id="first-name" class="block w-full border-gray-300 shadow-sm focus:ring-brand-accent focus:border-brand-accent sm:text-sm p-3 bg-white" required />
              </div>
              <div>
                <label for="last-name" class="block text-sm font-bold font-sans text-brand-blue mb-2 uppercase tracking-wide">Last Name</label>
                <input type="text" name="last-name" id="last-name" class="block w-full border-gray-300 shadow-sm focus:ring-brand-accent focus:border-brand-accent sm:text-sm p-3 bg-white" required />
              </div>
            </div>

            <div>
              <label for="email" class="block text-sm font-bold font-sans text-brand-blue mb-2 uppercase tracking-wide">Email</label>
              <input type="email" name="email" id="email" class="block w-full border-gray-300 shadow-sm focus:ring-brand-accent focus:border-brand-accent sm:text-sm p-3 bg-white" required />
            </div>

            <div>
              <label for="phone" class="block text-sm font-bold font-sans text-brand-blue mb-2 uppercase tracking-wide">Phone (Optional)</label>
              <input type="tel" name="phone" id="phone" class="block w-full border-gray-300 shadow-sm focus:ring-brand-accent focus:border-brand-accent sm:text-sm p-3 bg-white" />
            </div>

            <div>
              <label for="message" class="block text-sm font-bold font-sans text-brand-blue mb-2 uppercase tracking-wide">Project Details</label>
              <textarea id="message" name="message" rows="4" class="block w-full border-gray-300 shadow-sm focus:ring-brand-accent focus:border-brand-accent sm:text-sm p-3 bg-white" required></textarea>
            </div>

            <div>
              <button type="submit" class="w-full flex justify-center py-4 px-8 border border-transparent shadow-sm text-sm font-bold uppercase tracking-widest font-sans text-brand-bg bg-brand-blue hover:bg-brand-accent focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-blue transition-colors duration-300">
                Submit Inquiry
              </button>
            </div>
          </form>
        </div>

      </div>
    </div>
  </section>
  
  {/* Map Section */}
  <section class="h-96 w-full bg-gray-200">
    <iframe 
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3013.916174092494!2d-73.861715684581!3d41.06646737929452!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c2c069bc926e85%3A0xc6cb1dc2d5c8088!2s195%20S%20Broadway%2C%20Tarrytown%2C%20NY%2010591!5e0!3m2!1sen!2sus!4v1655123456789!5m2!1sen!2sus" 
      width="100%" 
      height="100%" 
      style="border:0;" 
      allowfullscreen="" 
      loading="lazy" 
      referrerpolicy="no-referrer-when-downgrade">
    </iframe>
  </section>
</BaseLayout>
