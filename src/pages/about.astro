---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
---

<BaseLayout
  title="Our Story"
  description="Continental Tile Contractors has been installing flooring since 1995. A third-generation family business serving NJ, NY, CT, and ME."
>
  {/* Page Header */}
  <section class="relative py-24 bg-brand-blue flex items-center justify-center">
    <div class="relative z-10 text-center max-w-4xl mx-auto px-4">
      <p class="font-sans text-xs font-bold uppercase tracking-[0.25em] text-brand-accent mb-4">Est. 1995</p>
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-brand-bg mb-5">Our Story</h1>
      <p class="font-sans text-base text-brand-bg/70 max-w-xl mx-auto">Three generations of flooring work, built on real relationships and consistent results.</p>
    </div>
  </section>

  {/* Main Content */}
  <section class="py-20 bg-brand-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-16 lg:gap-24 items-start">
        
        {/* Text column */}
        <div class="lg:col-span-3">
          <div class="prose prose-lg max-w-none font-sans text-gray-700 leading-relaxed">
            <p class="text-xl font-sans text-brand-blue font-semibold mb-6 leading-relaxed">
              Continental Tile Contractors has been in the flooring business since 1995. As a third-generation family operation, we've built our name on doing the work quick and doing the work right.
            </p>
            
            <p class="mb-6">
              We specialize in tile, LVT/LVP, and carpet installation for commercial and residential clients. Our work spans new construction, gut renovations, commercial fit-outs, and high-end residential projects. We work with general contractors, property managers, developers, and homeowners.
            </p>

            <p class="mb-10">
              Across 31 years, we've put flooring into office buildings, luxury apartments, retail spaces, healthcare facilities, and single-family homes across New York, New Jersey, Connecticut, and Maine. Our projects change, but our standard doesn't.
            </p>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 mb-12 border-t border-gray-200 pt-10">
            <div>
              <h2 class="font-sans text-xs font-bold uppercase tracking-[0.2em] text-brand-accent mb-3">Who We Work With</h2>
              <ul class="space-y-2 font-sans text-gray-700 text-sm">
                <li class="flex items-start gap-2"><span class="text-brand-accent mt-1 text-xs">▸</span> General Contractors</li>
                <li class="flex items-start gap-2"><span class="text-brand-accent mt-1 text-xs">▸</span> Property Managers</li>
                <li class="flex items-start gap-2"><span class="text-brand-accent mt-1 text-xs">▸</span> Developers & Builders</li>
                <li class="flex items-start gap-2"><span class="text-brand-accent mt-1 text-xs">▸</span> Homeowners</li>
                <li class="flex items-start gap-2"><span class="text-brand-accent mt-1 text-xs">▸</span> Architects & Interior Designers</li>
                <li class="flex items-start gap-2"><span class="text-brand-accent mt-1 text-xs">▸</span> And More!</li>

              </ul>
            </div>
            <div>
              <h2 class="font-sans text-xs font-bold uppercase tracking-[0.2em] text-brand-accent mb-3">Project Types</h2>
              <ul class="space-y-2 font-sans text-gray-700 text-sm">
                <li class="flex items-start gap-2"><span class="text-brand-accent mt-1 text-xs">▸</span> New Commercial Construction</li>
                <li class="flex items-start gap-2"><span class="text-brand-accent mt-1 text-xs">▸</span> Commercial Renovations & Fit-Outs</li>
                <li class="flex items-start gap-2"><span class="text-brand-accent mt-1 text-xs">▸</span> Multifamily & Luxury Residential</li>
                <li class="flex items-start gap-2"><span class="text-brand-accent mt-1 text-xs">▸</span> Healthcare & Hospitality</li>
                <li class="flex items-start gap-2"><span class="text-brand-accent mt-1 text-xs">▸</span> Retail & Auto Dealerships</li>
                <li class="flex items-start gap-2"><span class="text-brand-accent mt-1 text-xs">▸</span> And More!</li>
              </ul>
            </div>
          </div>

          <a href="/contact" class="inline-flex items-center gap-2 px-7 py-3.5 bg-brand-blue text-brand-bg font-sans font-bold uppercase tracking-widest text-xs hover:bg-brand-accent transition-colors duration-300">
            Start a Conversation
          </a>
        </div>

        {/* Stats Column - Anti-slop solid blocks entirely replacing the image */}
        <div class="lg:col-span-2 relative mt-10 lg:mt-0">
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-px bg-brand-blue/10 border border-brand-blue/10">
            <div class="bg-brand-bg py-12 px-8 text-center flex flex-col justify-center border-b border-brand-blue/5">
              <p class="font-serif text-6xl font-bold text-brand-blue mb-2">31</p>
              <p class="font-sans text-xs uppercase tracking-[0.2em] font-bold text-brand-accent">Years in Business</p>
            </div>
            <div class="bg-brand-bg py-12 px-8 text-center flex flex-col justify-center border-b border-brand-blue/5">
              <p class="font-serif text-6xl font-bold text-brand-blue mb-2">3rd</p>
              <p class="font-sans text-xs uppercase tracking-[0.2em] font-bold text-brand-accent">Generation</p>
            </div>
            <div class="sm:col-span-2 lg:col-span-1 bg-brand-bg py-12 px-8 text-center flex flex-col justify-center border-b border-brand-blue/5">
              <p class="font-serif text-6xl font-bold text-brand-blue mb-2">4</p>
              <p class="font-sans text-xs uppercase tracking-[0.2em] font-bold text-brand-accent">States Served</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  {/* Areas Served */}
  <section class="py-16 bg-brand-blue border-t border-brand-accent/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
        <div>
          <h2 class="font-sans text-xs font-bold uppercase tracking-[0.2em] text-brand-accent mb-3">Where We Work</h2>
          <h3 class="font-serif text-2xl font-bold text-brand-bg mb-2">Serving the Tri-State area and Maine</h3>
          <p class="font-sans text-brand-bg/70 text-sm max-w-xl leading-relaxed">
            We're based in Tarrytown, NY but regularly take on projects across Westchester County, Fairfield County, northern New Jersey, and the state of Maine. See all areas we serve.
          </p>
        </div>
        <a href="/areas" class="flex-shrink-0 inline-flex items-center gap-2 px-7 py-3.5 border border-brand-accent/50 text-brand-accent font-sans font-bold uppercase tracking-widest text-xs hover:bg-brand-accent hover:text-white hover:border-brand-accent transition-all duration-300">
          View All Areas
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
