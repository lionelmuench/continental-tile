---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';

// Placeholder portfolio images showcasing high-end commercial tile/flooring.
const projects = [
  { img: "https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&q=80&w=800", title: "Corporate Headquarters Lobby", type: "Large-Format Porcelain" },
  { img: "https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&q=80&w=800", title: "Luxury Retail Boutique", type: "Ceramic & Marble Overlay" },
  { img: "https://images.unsplash.com/photo-1497366811353-6870744d04b2?auto=format&fit=crop&q=80&w=800", title: "Modern Office Workspace", type: "Commercial Broadloom Carpet" },
  { img: "https://images.unsplash.com/photo-1618221195710-dd6b41faaea6?auto=format&fit=crop&q=80&w=800", title: "Hospitality Corridor", type: "Luxury Vinyl Plank (LVP)" },
  { img: "https://images.unsplash.com/photo-1545601445-4d6a0a0565f0?auto=format&fit=crop&q=80&w=800", title: "Healthcare Facility", type: "Seamless Vinyl Coved" },
  { img: "https://images.unsplash.com/photo-1504307651254-35680f356dfd?auto=format&fit=crop&q=80&w=800", title: "Executive Restrooms", type: "Custom Floor & Wall Slate" }
];
---

<BaseLayout title="Portfolio - Our Work">
  {/* Page Header */}
  <section class="relative py-32 bg-brand-blue flex items-center justify-center border-b border-brand-accent/20">
    <div class="relative z-10 text-center max-w-4xl mx-auto px-4">
      <h1 class="font-serif text-5xl md:text-6xl font-bold text-brand-bg mb-6">Our Portfolio</h1>
      <p class="font-sans text-xl text-brand-accent tracking-widest uppercase font-semibold">Decades of Proven Excellence</p>
    </div>
  </section>

  <section class="py-24 bg-brand-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="flex flex-col md:flex-row justify-between items-end mb-16 border-b border-brand-accent/30 pb-8">
        <div class="max-w-xl">
          <p class="font-sans text-lg text-gray-600 leading-relaxed">
            Explore our diverse range of commercial and residential installations. Our commitment to rigorous standards and unparalleled craftsmanship is evident in every project.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map((project) => (
          <div class="group relative overflow-hidden bg-white shadow-md hover:shadow-2xl transition-all duration-500 block">
            <div class="aspect-w-4 aspect-h-3 overflow-hidden">
              <Image 
                src={project.img} 
                alt={project.title}
                width={800}
                height={600}
                format="webp" 
                class="w-full h-72 object-cover transform group-hover:scale-105 transition-transform duration-700 ease-out"
              />
            </div>
            
            <div class="absolute inset-0 bg-gradient-to-t from-brand-blue/90 via-brand-blue/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-6">
              <span class="font-sans text-brand-accent uppercase tracking-widest text-xs font-bold mb-2 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                {project.type}
              </span>
              <h3 class="font-serif text-xl font-bold text-white transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300 delay-75">
                {project.title}
              </h3>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-20 text-center">
        <h2 class="font-serif text-3xl font-bold text-brand-blue mb-8">Ready to elevate your space?</h2>
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 border border-transparent text-sm font-bold tracking-wide uppercase font-sans text-brand-bg bg-brand-blue hover:bg-brand-accent transition-colors duration-300 shadow-xl">
          Start a Conversation
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
